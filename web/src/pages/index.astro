---
import Layout from '../layouts/Layout.astro'

// --- Featured skills: build-time fetch from Runics API ---
type LeaderboardEntry = {
  id: string
  slug: string
  name: string
  trustScore: number
}

type SkillDetail = {
  id: string
  slug: string
  name: string
  description: string | null
  agentSummary: string | null
  trustScore: number
  verificationTier: string | null
  source: string | null
  sourceUrl: string | null
  category: string | null
  shareUrl: string | null
}

async function fetchWithTimeout(url: string, ms = 5000): Promise<Response | null> {
  const controller = new AbortController()
  const timer = setTimeout(() => controller.abort(), ms)
  try {
    const res = await fetch(url, { signal: controller.signal, headers: { 'User-Agent': 'runics-web-build' } })
    return res.ok ? res : null
  } catch {
    return null
  } finally {
    clearTimeout(timer)
  }
}

async function loadFeaturedSkills(): Promise<SkillDetail[]> {
  const res = await fetchWithTimeout('https://api.runics.net/v1/leaderboards/human?limit=50')
  if (!res) return []
  const data = (await res.json().catch(() => null)) as { leaderboard?: LeaderboardEntry[] } | null
  if (!data?.leaderboard?.length) return []

  const top = [...data.leaderboard]
    .filter(e => typeof e.trustScore === 'number' && e.slug)
    .sort((a, b) => b.trustScore - a.trustScore)
    .slice(0, 6)

  const details = await Promise.all(
    top.map(async (entry) => {
      const r = await fetchWithTimeout(`https://api.runics.net/v1/skills/${encodeURIComponent(entry.slug)}`)
      if (!r) return null
      return (await r.json().catch(() => null)) as SkillDetail | null
    })
  )

  return details.filter((d): d is SkillDetail => !!d && !!d.slug)
}

const featuredSkills = await loadFeaturedSkills()

const faqs = [
  {
    q: 'What is Runics?',
    a: 'Runics is a semantic skill registry for AI agents. It indexes over 61,000 agent skills from sources like the MCP Registry, Smithery, ClawHub, Glama, and GitHub, then ranks them by a security trust score computed by Cognium. Agents and developers can search by natural language and get results ranked by relevance, trust, and real usage.',
  },
  {
    q: 'How is Runics different from the MCP Registry and ClawHub?',
    a: 'The MCP Registry and ClawHub list skills but rely on keyword matching and do not score skills for security. Runics adds semantic search (vector embeddings plus cross-encoder reranking), vulnerability and prompt-injection scanning via Cognium, a continuously updated trust score, and confidence signals that tell an agent how certain a match is. Runics also aggregates skills from multiple sources in a single search.',
  },
  {
    q: 'What is a trust score and how is it computed?',
    a: 'A trust score is a 0–1 rating assigned to every indexed skill. It is produced by Cognium, which scans each skill for known vulnerabilities, license problems, unsafe permissions, and prompt-injection patterns. Scores update continuously as new scans run and as usage signals arrive. Versions are ranked by trust × 0.7 + usage × 0.3, so the most reliable version surfaces first rather than simply the newest.',
  },
  {
    q: 'What sources does Runics index?',
    a: 'Runics aggregates skills from the MCP Registry, Smithery, PulseMCP, ClawHub, Glama, OpenClaw, GitHub repositories, and a human-curated source. All are normalized into a single search index, so one query returns results across every ecosystem.',
  },
  {
    q: 'How does the 3-tier intelligence search work?',
    a: 'Queries are routed through three tiers by confidence. Tier 1 is a fast vector similarity search; if the top results are clearly relevant, they are returned immediately with sub-60ms p50 latency. Tier 2 adds a cross-encoder reranker for medium-confidence matches. Tier 3 invokes an LLM for deep search and composition detection when the query is complex or ambiguous. Every response includes the tier used, confidence label, and latency.',
  },
  {
    q: 'Is the Runics API free?',
    a: 'Yes. Search is free and does not require authentication. Send a POST request to https://api.runics.net/v1/search with a JSON body containing a query and a tenantId. Rate limits apply for abuse prevention but are not publicly enforced for ordinary use.',
  },
  {
    q: 'What is composition detection?',
    a: 'Composition detection identifies queries that require more than one skill. For example, the query "format my code and check for license issues" is automatically decomposed: Runics finds a formatting skill and a license-scanning skill, and suggests composing them. This is returned as a structured composition object in the API response.',
  },
]

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 border-b border-border-subtle bg-bg/80 backdrop-blur-xl" aria-label="Primary">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5" aria-label="Runics home">
        <svg viewBox="0 0 32 32" fill="none" class="w-7 h-7" aria-hidden="true">
          <path d="M8 10L16 6L24 10V16L16 26L8 16V10Z" stroke="#6ee7b7" stroke-width="1.5" fill="none"/>
          <circle cx="16" cy="14" r="3" fill="#6ee7b7" opacity="0.8"/>
        </svg>
        <span class="text-text-primary font-semibold text-lg tracking-tight">Runics</span>
      </a>
      <div class="flex items-center gap-4 sm:gap-6">
        <a href="https://api.runics.net/health" target="_blank" rel="noopener" class="text-sm text-text-muted hover:text-text-secondary transition-colors">
          <span class="sm:hidden">Status</span>
          <span class="hidden sm:inline">API Status</span>
        </a>
        <a href="#features" class="text-sm text-text-muted hover:text-text-secondary transition-colors">Features</a>
        {featuredSkills.length > 0 && (
          <a href="#featured" class="hidden sm:inline text-sm text-text-muted hover:text-text-secondary transition-colors">Featured</a>
        )}
        <a href="#faq" class="text-sm text-text-muted hover:text-text-secondary transition-colors">FAQ</a>
        <a href="https://cognium.net" target="_blank" rel="noopener" class="hidden sm:flex items-center gap-1.5 text-sm text-text-muted hover:text-text-secondary transition-colors" title="Powered by Cognium">
          <svg viewBox="0 0 32 25" class="w-5 h-4" fill="none" aria-hidden="true">
            <path d="M3.9 6 C9.8 6, 12.8 9.2, 15.7 11.8" stroke="#64748B" stroke-width="2.2" stroke-linecap="round"/>
            <path d="M3.9 19 C9.8 19, 12.8 16, 15.7 13.5" stroke="#A8B5C2" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="16.2" cy="12.6" r="2.5" fill="#E5A820"/>
            <path d="M19 12.2 C23 11.5, 26 10.5, 29 9.6" stroke="#E5A820" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span class="hidden lg:inline">Cognium</span>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <main class="pt-14">
    <section class="relative overflow-hidden">
      <!-- Gradient bg -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(110,231,183,0.08)_0%,transparent_60%)]"></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-20 md:pt-28 pb-16 md:pb-20 text-center">
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight leading-[1.08]">
          Every agent skill.<br/>
          <span class="text-accent">Trust-scored.</span>
        </h1>

        <p class="mt-6 text-base sm:text-lg md:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed animate-fade-up-delay">
          Semantic search across the entire agent skill ecosystem.
          Security-scanned by Cognium. Ranked by trust and usage.
        </p>

        <!-- Search bar -->
        <div class="mt-12 max-w-2xl mx-auto animate-fade-up-delay-2" role="search">
          <label for="search-input" class="sr-only">Search Runics for agent skills</label>
          <div class="relative group">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-accent/20 via-accent/5 to-accent/20 rounded-2xl blur-sm opacity-0 group-focus-within:opacity-100 transition-opacity duration-300"></div>
            <div class="relative flex items-center bg-bg-card border border-border rounded-xl overflow-hidden">
              <svg class="w-5 h-5 ml-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
              </svg>
              <input
                id="search-input"
                type="search"
                name="q"
                placeholder="Search skills... e.g. &quot;format code with prettier&quot;"
                class="w-full py-4 px-4 bg-transparent text-text-primary placeholder:text-text-muted outline-none text-base"
                autocomplete="off"
                aria-label="Search agent skills by natural language"
              />
              <kbd class="hidden md:inline-flex items-center mr-4 px-2 py-0.5 rounded border border-border text-[11px] text-text-muted font-mono shrink-0" aria-label="Press slash to focus search">/</kbd>
            </div>
          </div>

          <!-- Search results container -->
          <div id="search-results" class="mt-3 hidden" role="region" aria-live="polite" aria-label="Search results"></div>
        </div>

        <!-- Example queries -->
        <div class="mt-6 flex flex-wrap justify-center gap-2 animate-fade-up-delay-2">
          {['web scraping', 'send email', 'database tools', 'image generation'].map(q => (
            <button
              class="search-example px-3.5 py-2 text-xs rounded-lg border border-border-subtle text-text-muted hover:text-text-secondary hover:border-border hover:bg-bg-card transition-all cursor-pointer min-h-[36px]"
              data-query={q}
            >
              {q}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats bar -->
    <section class="border-y border-border-subtle bg-bg-elevated/50">
      <div class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { value: '61K+', label: 'Skills indexed' },
          { value: '<60ms', label: 'Search latency (p50)' },
          { value: '8', label: 'Skill sources' },
          { value: '3-tier', label: 'Confidence routing' },
        ].map(stat => (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-bold text-text-primary font-mono">{stat.value}</div>
            <div class="mt-1 text-sm text-text-muted">{stat.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-12 md:mb-16">
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Built for agents that need to <span class="text-accent">trust</span> their tools</h2>
          <p class="mt-4 text-text-secondary max-w-xl mx-auto">Every skill is security-scanned, semantically indexed, and ranked by real usage signals.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
          {[
            {
              title: 'Semantic Search',
              desc: 'Natural language queries ranked by confidence, not keyword matching.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />`,
            },
            {
              title: 'Trust Scores',
              desc: 'Cognium scans every skill for vulnerabilities, license issues, and prompt injection.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
            },
            {
              title: '3-Tier Intelligence',
              desc: 'Vector search, cross-encoder reranking, and LLM fallback -- escalates automatically by confidence.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
            },
            {
              title: 'Multi-Source',
              desc: 'One search across MCP Registry, Smithery, PulseMCP, ClawHub, Glama, OpenClaw, GitHub, and human-curated sources.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z" />`,
            },
            {
              title: 'Version Ranking',
              desc: 'Ranked by trust x 0.7 + usage x 0.3. Most reliable version surfaces first.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5-3L16.5 18m0 0L12 13.5m4.5 4.5V6" />`,
            },
            {
              title: 'Composition Detection',
              desc: 'Multi-skill queries auto-decomposed. "Format code and check licenses" finds both.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.546 3.16 1.058 4.62M16.5 15.75h-9m9 0a3 3 0 013 3V21h-12v-2.25a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 15.75v-3.375c0-.621.504-1.125 1.125-1.125h.872" />`,
            },
          ].map(feature => (
            <div class="group p-6 rounded-xl border border-border-subtle bg-bg-card hover:bg-bg-card-hover hover:border-border transition-all duration-200">
              <div class="w-10 h-10 rounded-lg bg-accent-glow flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <Fragment set:html={feature.icon} />
                </svg>
              </div>
              <h3 class="text-base font-semibold text-text-primary">{feature.title}</h3>
              <p class="mt-2 text-sm text-text-secondary leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Skills -->
    {featuredSkills.length > 0 && (
      <section id="featured" class="py-16 md:py-24 border-t border-border-subtle">
        <div class="max-w-6xl mx-auto px-6">
          <div class="text-center mb-12 md:mb-16">
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
              Featured <span class="text-accent">high-trust</span> skills
            </h2>
            <p class="mt-4 text-text-secondary max-w-xl mx-auto">
              Ranked by Cognium trust score. Updates continuously as new scans run.
            </p>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {featuredSkills.map(skill => {
              const trustPct = Math.round((skill.trustScore || 0) * 100)
              const trustTextCls = skill.trustScore >= 0.8 ? 'text-green-400' : skill.trustScore >= 0.6 ? 'text-yellow-400' : 'text-red-400'
              const trustBarCls = skill.trustScore >= 0.8 ? 'bg-green-400' : skill.trustScore >= 0.6 ? 'bg-yellow-400' : 'bg-red-400'
              const href = skill.slug ? `/skills/${skill.slug}` : (skill.sourceUrl || skill.shareUrl || '#')
              const hasLink = href !== '#'
              const isInternal = href.startsWith('/')
              const description = skill.description || skill.agentSummary || ''
              return (
                <a
                  href={href}
                  target={hasLink && !isInternal ? '_blank' : undefined}
                  rel={hasLink && !isInternal ? 'noopener' : undefined}
                  class="group p-5 rounded-xl border border-border-subtle bg-bg-card hover:bg-bg-card-hover hover:border-border transition-all duration-200 flex flex-col"
                  aria-label={`${skill.name} — trust score ${trustPct} percent`}
                >
                  <div class="flex items-start justify-between gap-3 mb-3">
                    <div class="flex items-center gap-1.5 min-w-0 flex-wrap">
                      {skill.source && (
                        <span class="text-[10px] px-1.5 py-0.5 rounded bg-bg-elevated border border-border-subtle text-text-muted font-mono uppercase tracking-wide">
                          {skill.source}
                        </span>
                      )}
                      {skill.verificationTier && skill.verificationTier !== 'unverified' && (
                        <span class="text-[10px] px-1.5 py-0.5 rounded bg-accent-glow border border-accent/30 text-accent font-mono uppercase tracking-wide">
                          {skill.verificationTier}
                        </span>
                      )}
                    </div>
                    <div class="text-right shrink-0">
                      <div class={`text-sm font-mono font-semibold ${trustTextCls}`}>{trustPct}%</div>
                      <div class="text-[10px] text-text-muted uppercase tracking-wide">trust</div>
                    </div>
                  </div>

                  <div class="h-1 rounded-full bg-bg-elevated overflow-hidden mb-4" aria-hidden="true">
                    <div class={`h-full ${trustBarCls}`} style={`width: ${trustPct}%`}></div>
                  </div>

                  <h3 class="text-base font-semibold text-text-primary leading-snug line-clamp-2 group-hover:text-accent transition-colors">
                    {skill.name}
                  </h3>

                  {description && (
                    <p class="mt-2 text-sm text-text-secondary leading-relaxed line-clamp-3 flex-1">
                      {description}
                    </p>
                  )}

                  <div class="mt-4 text-xs text-text-muted font-mono truncate" title={skill.slug}>
                    {skill.slug}
                  </div>
                </a>
              )
            })}
          </div>

          <p class="mt-10 text-center text-sm text-text-muted">
            Security-scanned by
            <a href="https://cognium.net" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-text-secondary hover:text-text-primary transition-colors">
              <svg viewBox="0 0 32 25" class="w-4 h-3 inline-block" fill="none" aria-hidden="true">
                <path d="M3.9 6 C9.8 6, 12.8 9.2, 15.7 11.8" stroke="#64748B" stroke-width="2.2" stroke-linecap="round"/>
                <path d="M3.9 19 C9.8 19, 12.8 16, 15.7 13.5" stroke="#A8B5C2" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="16.2" cy="12.6" r="2.5" fill="#E5A820"/>
                <path d="M19 12.2 C23 11.5, 26 10.5, 29 9.6" stroke="#E5A820" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
              Cognium</a>. Trust scores update continuously.
          </p>
        </div>
      </section>
    )}

    <!-- FAQ -->
    <section id="faq" class="py-16 md:py-24 border-t border-border-subtle bg-bg-elevated/30">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-12 md:mb-16">
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Frequently asked questions</h2>
          <p class="mt-4 text-text-secondary">What Runics is, how it works, and how to use it.</p>
        </div>

        <div class="flex flex-col gap-3">
          {faqs.map(item => (
            <details class="group rounded-xl border border-border-subtle bg-bg-card hover:border-border transition-colors">
              <summary class="cursor-pointer list-none p-5 flex items-start justify-between gap-4">
                <h3 class="text-base font-semibold text-text-primary leading-snug">{item.q}</h3>
                <svg class="w-5 h-5 shrink-0 text-text-muted transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-text-secondary leading-relaxed">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-24 border-t border-border-subtle">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Start searching</h2>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#" onclick="document.getElementById('search-input').focus(); window.scrollTo({top: 0, behavior: 'smooth'}); return false;" class="px-6 py-3 rounded-xl bg-accent text-bg font-semibold text-sm hover:bg-accent-dim transition-colors">
            Try a search
          </a>
          <a href="https://api.runics.net/health" target="_blank" class="px-6 py-3 rounded-xl border border-border text-text-secondary font-medium text-sm hover:text-text-primary hover:border-border transition-colors">
            View API
          </a>
        </div>

        <!-- curl example -->
        <div class="mt-10 max-w-xl mx-auto">
          <pre class="text-left p-5 rounded-xl bg-bg-card border border-border-subtle text-sm font-mono overflow-x-auto"><code class="text-text-secondary"><span class="text-text-muted">$</span> curl -X POST https://api.runics.net/v1/search \
  -H <span class="text-accent">"Content-Type: application/json"</span> \
  -d <span class="text-accent">'&#123;"query": "web scraping", "tenantId": "public"&#125;'</span></code></pre>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-border-subtle py-10">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3 text-sm text-text-muted">
          <a href="/" class="flex items-center gap-1.5 hover:text-text-secondary transition-colors">
            <svg viewBox="0 0 32 32" fill="none" class="w-5 h-5" aria-hidden="true">
              <path d="M8 10L16 6L24 10V16L16 26L8 16V10Z" stroke="#6ee7b7" stroke-width="1.5" fill="none"/>
              <circle cx="16" cy="14" r="3" fill="#6ee7b7" opacity="0.8"/>
            </svg>
            Runics
          </a>
          <span class="text-border" aria-hidden="true">|</span>
          <a href="https://cognium.net" target="_blank" rel="noopener" class="flex items-center gap-1.5 hover:text-text-secondary transition-colors">
            <svg viewBox="0 0 32 25" class="w-5 h-4" fill="none" aria-hidden="true">
              <path d="M3.9 6 C9.8 6, 12.8 9.2, 15.7 11.8" stroke="#64748B" stroke-width="2.2" stroke-linecap="round"/>
              <path d="M3.9 19 C9.8 19, 12.8 16, 15.7 13.5" stroke="#A8B5C2" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="16.2" cy="12.6" r="2.5" fill="#E5A820"/>
              <path d="M19 12.2 C23 11.5, 26 10.5, 29 9.6" stroke="#E5A820" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            Cognium Labs
          </a>
        </div>
        <nav class="flex items-center gap-6 text-sm text-text-muted" aria-label="Footer">
          <a href="https://api.runics.net/health" target="_blank" rel="noopener" class="hover:text-text-secondary transition-colors">API</a>
          <a href="#faq" class="hover:text-text-secondary transition-colors">FAQ</a>
        </nav>
      </div>
    </footer>
  </main>

  <!-- FAQ structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Featured skills data for instant local search -->
  <script is:inline define:vars={{ featuredSkills }}>
    window.__featuredSkills = featuredSkills;
  </script>

  <!-- Search JS -->
  <script>
    const API = 'https://api.runics.net';
    const input = document.getElementById('search-input') as HTMLInputElement;
    const resultsEl = document.getElementById('search-results')!;
    let debounceTimer: ReturnType<typeof setTimeout>;
    let abortController: AbortController | null = null;
    const localSkills: any[] = (window as any).__featuredSkills || [];
    let currentQuery = '';
    let lastData: any = null;
    let visibleCount = 5;
    const INITIAL_VISIBLE = 5;
    const FETCH_LIMIT = 20;

    // Keyboard shortcut
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== input) {
        e.preventDefault();
        input.focus();
      }
    });

    // Example queries — search immediately (no debounce)
    document.querySelectorAll('.search-example').forEach(btn => {
      btn.addEventListener('click', () => {
        const q = (btn as HTMLElement).dataset.query || '';
        input.value = q;
        doSearch(q);
        input.focus();
      });
    });

    // Search on Enter immediately, debounce on typing (500ms)
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const q = input.value.trim();
      if (q.length < 2) {
        abortController?.abort();
        resultsEl.classList.add('hidden');
        resultsEl.innerHTML = '';
        return;
      }
      debounceTimer = setTimeout(() => doSearch(q), 500);
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.isComposing) {
        clearTimeout(debounceTimer);
        const q = input.value.trim();
        if (q.length >= 2) {
          // Let keyboard nav handler run first (it checks activeResultIdx)
          // Only trigger search if no result is highlighted
          if (activeResultIdx < 0) {
            doSearch(q);
          }
        }
      }
    });

    // Auto-search if landed with ?q=<query>
    const urlQuery = new URLSearchParams(window.location.search).get('q');
    if (urlQuery && urlQuery.length >= 2) {
      input.value = urlQuery;
      doSearch(urlQuery);
    }

    let activeResultIdx = -1;

    function localSearch(query: string): any[] {
      if (!localSkills.length) return [];
      const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
      return localSkills
        .map(s => {
          const text = `${s.name || ''} ${s.slug || ''} ${s.description || ''} ${s.agentSummary || ''}`.toLowerCase();
          const score = terms.reduce((acc: number, t: string) => acc + (text.includes(t) ? 1 : 0), 0);
          return { ...s, _score: score };
        })
        .filter(s => s._score > 0)
        .sort((a, b) => b._score - a._score)
        .slice(0, 3);
    }

    function renderLocalResults(matches: any[]) {
      const html = matches.map((r: any) => {
        const name = escapeHtml(r.name || r.slug || 'unnamed');
        const summary = escapeHtml(r.description || r.agentSummary || '');
        const trustPct = ((r.trustScore || 0) * 100).toFixed(0);
        const href = r.slug ? `/skills/${encodeURIComponent(r.slug)}` : '#';
        return `
          <a href="${href}" class="block p-4 rounded-xl border border-border-subtle bg-bg-card hover:bg-bg-card-hover hover:border-accent/50 transition-all">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0 flex-1">
                <span class="font-semibold text-text-primary text-sm truncate">${name}</span>
                ${summary ? `<p class="mt-1 text-xs text-text-secondary line-clamp-2">${summary}</p>` : ''}
              </div>
              <div class="shrink-0 text-right">
                <div class="text-xs font-mono ${trustColor(r.trustScore || 0)}">${trustPct}%</div>
              </div>
            </div>
          </a>`;
      }).join('');
      return `<div class="flex flex-col gap-2" id="results-list">${html}</div>
        <div class="flex items-center justify-center gap-2 mt-2 text-xs text-text-muted"><svg class="w-3 h-3 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.25"/><path d="M12 2a10 10 0 019.95 9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>Loading full results…</div>`;
    }

    function renderSkeletons(count = 3): string {
      const skeleton = Array.from({ length: count }, () => `
        <div class="p-4 rounded-xl border border-border-subtle bg-bg-card animate-pulse">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0 flex-1 space-y-2">
              <div class="h-4 bg-bg-elevated rounded w-2/5"></div>
              <div class="h-3 bg-bg-elevated rounded w-4/5"></div>
              <div class="h-3 bg-bg-elevated rounded w-3/5"></div>
            </div>
            <div class="shrink-0 space-y-1.5">
              <div class="h-3 bg-bg-elevated rounded w-8 ml-auto"></div>
              <div class="h-3 bg-bg-elevated rounded w-12 ml-auto"></div>
            </div>
          </div>
        </div>`).join('');
      return `<div class="flex flex-col gap-2">${skeleton}</div>`;
    }

    async function doSearch(query: string) {
      activeResultIdx = -1;
      currentQuery = query;
      visibleCount = INITIAL_VISIBLE;

      // Cancel any in-flight request
      abortController?.abort();
      abortController = new AbortController();
      const signal = abortController.signal;

      // Show instant local results (if any) while API loads, or skeletons
      const localMatches = localSearch(query);
      if (localMatches.length > 0) {
        resultsEl.innerHTML = renderLocalResults(localMatches);
      } else {
        resultsEl.innerHTML = renderSkeletons();
      }
      resultsEl.classList.remove('hidden');

      try {
        const res = await fetch(`${API}/v1/search`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query, tenantId: 'public', limit: FETCH_LIMIT }),
          signal,
        });
        if (!res.ok) throw new Error(`${res.status}`);
        const data = await res.json();
        if (!signal.aborted) {
          lastData = data;
          renderResults(data);
        }
      } catch (e: any) {
        if (e?.name === 'AbortError') return;
        if (localMatches.length > 0) {
          const loader = resultsEl.querySelector('.animate-spin')?.closest('div:not(#results-list)');
          if (loader) loader.innerHTML = `<span class="text-xs text-text-muted">Showing featured results only</span>`;
        } else {
          resultsEl.innerHTML = `<div class="p-4 rounded-xl border border-red-400/20 bg-bg-card text-sm text-text-muted text-center">
            <p class="text-red-400">Search unavailable</p>
            <button id="retry-btn" class="mt-2 px-4 py-1.5 text-xs rounded-lg border border-border text-text-secondary hover:text-text-primary hover:border-accent/50 transition-all cursor-pointer">Retry</button>
          </div>`;
          resultsEl.classList.remove('hidden');
          document.getElementById('retry-btn')?.addEventListener('click', () => doSearch(query));
        }
      }
    }

    function showMore() {
      if (!lastData) return;
      visibleCount = Math.min(visibleCount + 5, lastData.results.length);
      renderResults(lastData);
    }

    // Expose for inline handlers
    (window as any).doSearch = doSearch;

    function trustColor(score: number): string {
      if (score >= 0.8) return 'text-green-400';
      if (score >= 0.6) return 'text-yellow-400';
      return 'text-red-400';
    }

    function confidenceClass(c: string): string {
      if (c === 'high') return 'bg-accent-glow border-accent/30 text-accent';
      if (c === 'medium') return 'bg-yellow-400/10 border-yellow-400/30 text-yellow-400';
      if (c === 'low_enriched') return 'bg-orange-400/10 border-orange-400/30 text-orange-400';
      return 'bg-bg-elevated border-border-subtle text-text-muted';
    }

    function latencyClass(ms: number): string {
      if (ms < 100) return 'text-green-400';
      if (ms < 300) return 'text-yellow-400';
      return 'text-orange-400';
    }

    function tierLabel(tier: number): string {
      if (tier === 1) return 'Vector';
      if (tier === 2) return 'Reranked';
      if (tier === 3) return 'LLM';
      return `Tier ${tier}`;
    }

    function tierDots(tier: number): string {
      const colors = ['bg-accent', 'bg-yellow-400', 'bg-orange-400'];
      return [1, 2, 3].map(i => {
        const active = i <= tier;
        const cls = active ? colors[i - 1] : 'bg-border';
        return `<span class="inline-block w-1.5 h-1.5 rounded-full ${cls}"></span>`;
      }).join('');
    }

    function escapeHtml(s: string): string {
      return String(s).replace(/[&<>"']/g, ch => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch] as string));
    }

    function renderResults(data: any) {
      if (!data.results || data.results.length === 0) {
        resultsEl.innerHTML = `<div class="p-4 rounded-xl border border-border-subtle bg-bg-card text-sm text-text-muted text-center">No results found. Try a different query.</div>`;
        resultsEl.classList.remove('hidden');
        return;
      }

      const meta = data.meta || {};
      const tier = meta.tier || 1;
      const latency = meta.latencyMs || 0;
      const confidence = data.confidence || 'unknown';
      const totalResults = data.results.length;
      const visible = data.results.slice(0, visibleCount);
      const hasMore = visibleCount < totalResults;

      const metaPanel = `
        <div class="flex flex-wrap items-center gap-2 p-3 rounded-xl border border-border-subtle bg-bg-card mb-2 text-xs" aria-label="Search routing metadata">
          <span class="inline-flex items-center gap-1.5 font-mono text-text-secondary" title="Routing tier ${tier}: ${tierLabel(tier)}">
            <span class="inline-flex items-center gap-1" aria-hidden="true">${tierDots(tier)}</span>
            <span class="text-[10px] uppercase tracking-wide">${tierLabel(tier)}</span>
          </span>
          <span class="inline-block w-px h-3 bg-border-subtle" aria-hidden="true"></span>
          <span class="inline-flex items-center px-2 py-0.5 rounded border font-mono ${confidenceClass(confidence)}" title="Confidence: ${escapeHtml(confidence)}">
            ${escapeHtml(confidence)}
          </span>
          <span class="inline-flex items-center px-2 py-0.5 rounded border border-border-subtle bg-bg-elevated font-mono ${latencyClass(latency)}" title="Latency">
            ${latency}ms
          </span>
          ${meta.reranked ? '<span class="inline-flex items-center px-2 py-0.5 rounded border border-border-subtle bg-bg-elevated text-text-muted font-mono" title="Cross-encoder reranking applied">reranked</span>' : ''}
          ${meta.llmInvoked ? '<span class="inline-flex items-center px-2 py-0.5 rounded border border-border-subtle bg-bg-elevated text-text-muted font-mono" title="LLM deep search invoked">LLM</span>' : ''}
          ${meta.cacheHit ? '<span class="inline-flex items-center px-2 py-0.5 rounded border border-border-subtle bg-bg-elevated text-text-muted font-mono" title="Served from cache">cached</span>' : ''}
          <span class="ml-auto text-text-muted">${hasMore ? `${visibleCount} of ${totalResults}` : `${totalResults}`} result${totalResults === 1 ? '' : 's'}</span>
        </div>
      `;

      const html = visible.map((r: any, idx: number) => {
        const name = escapeHtml(r.name || r.slug || 'unnamed');
        const summary = escapeHtml(r.agentSummary || '');
        const matchSrc = r.matchSource ? escapeHtml(String(r.matchSource).replace(/_/g, ' ')) : null;
        const trustPct = ((r.trustScore || 0) * 100).toFixed(0);
        const relevancePct = ((r.score || 0) * 100).toFixed(0);
        const href = r.slug ? `/skills/${encodeURIComponent(r.slug)}` : null;
        const openTag = href ? `<a href="${href}" class="block p-4 rounded-xl border border-border-subtle bg-bg-card hover:bg-bg-card-hover hover:border-accent/50 transition-all">` : `<div class="p-4 rounded-xl border border-border-subtle bg-bg-card">`;
        const closeTag = href ? `</a>` : `</div>`;
        return `
          ${openTag}
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-xs text-text-muted font-mono mr-0.5">${idx + 1}.</span>
                  <span class="font-semibold text-text-primary text-sm truncate">${name}</span>
                  ${matchSrc ? `<span class="text-[10px] px-1.5 py-0.5 rounded bg-bg-elevated border border-border-subtle text-text-muted font-mono uppercase tracking-wide" title="Matched on: ${matchSrc}">${matchSrc}</span>` : ''}
                </div>
                ${summary ? `<p class="mt-1 text-xs text-text-secondary line-clamp-2">${summary}</p>` : ''}
              </div>
              <div class="shrink-0 text-right">
                <div class="text-xs font-mono text-text-secondary" title="Relevance score">${relevancePct}%</div>
                <div class="text-[10px] font-mono ${trustColor(r.trustScore || 0)} mt-0.5" title="Trust score">${trustPct}% trust</div>
              </div>
            </div>
          ${closeTag}
        `;
      }).join('');

      const showMoreBtn = hasMore
        ? `<button id="show-more-btn" class="mt-2 w-full py-2.5 text-xs rounded-xl border border-border-subtle bg-bg-card hover:bg-bg-card-hover hover:border-border text-text-muted hover:text-text-secondary transition-all cursor-pointer">Show more (${totalResults - visibleCount} remaining)</button>`
        : '';

      resultsEl.innerHTML = `${metaPanel}<div class="flex flex-col gap-2" id="results-list">${html}</div>${showMoreBtn}`;
      resultsEl.classList.remove('hidden');
      activeResultIdx = -1;

      // Bind "Show more" button
      document.getElementById('show-more-btn')?.addEventListener('click', showMore);
    }

    // Keyboard navigation: ↑↓ to move, Enter to open, Esc to close
    input.addEventListener('keydown', (e) => {
      const list = document.getElementById('results-list');
      if (!list) return;
      const items = list.querySelectorAll<HTMLElement>('a, div.p-4');
      if (items.length === 0) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeResultIdx = Math.min(activeResultIdx + 1, items.length - 1);
        highlightResult(items);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeResultIdx = Math.max(activeResultIdx - 1, 0);
        highlightResult(items);
      } else if (e.key === 'Enter' && activeResultIdx >= 0) {
        e.preventDefault();
        const link = items[activeResultIdx]?.closest('a') || items[activeResultIdx]?.querySelector('a');
        if (link) (link as HTMLAnchorElement).click();
      } else if (e.key === 'Escape') {
        resultsEl.classList.add('hidden');
        resultsEl.innerHTML = '';
        activeResultIdx = -1;
      }
    });

    function highlightResult(items: NodeListOf<HTMLElement>) {
      items.forEach((el, i) => {
        if (i === activeResultIdx) {
          el.classList.add('ring-1', 'ring-accent/50');
          el.scrollIntoView({ block: 'nearest' });
        } else {
          el.classList.remove('ring-1', 'ring-accent/50');
        }
      });
    }
  </script>
</Layout>
