{
  "name": "runics",
  "version": "1.0.0",
  "description": "Semantic skill registry search service for the Runics platform",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy",
    "deploy:production": "wrangler deploy -c wrangler.production.toml",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:test": "tsx scripts/test-db.ts",
    "seed": "tsx scripts/seed-eval-skills.ts",
    "eval": "tsx scripts/run-eval.ts",
    "verify:cognium": "tsx scripts/run-cognium-verify.ts",
    "analyze-baseline": "tsx scripts/analyze-baseline.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "perf": "tsx scripts/perf-test.ts",
    "perf:staging": "tsx scripts/perf-test.ts --endpoint https://runics.phantoms.workers.dev",
    "perf:production": "tsx scripts/perf-test.ts --endpoint https://api.runics.net"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.1",
    "@neondatabase/serverless": "^0.10.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.0.0",
    "nanoid": "^5.1.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.70.0"
  }
}
